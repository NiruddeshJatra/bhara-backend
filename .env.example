# Core Settings
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Production only - for development, SQLite is used)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Cache & Celery (Production only - for development, LocMem cache and eager tasks are used)
REDIS_URL=redis://127.0.0.1:6379/1

# SMS Service
ALPHA_SMS_API_KEY=

# AWS S3 (Production only)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-southeast-1

# R2: https://<account_id>.r2.cloudflarestorage.com — leave empty for AWS S3
AWS_S3_ENDPOINT_URL=

# 'auto' for R2; e.g. ap-southeast-1 for AWS S3
AWS_S3_REGION_NAME=auto

# Public media domain (R2 public bucket / CDN). When set, MEDIA_URL=https://<domain>/
AWS_S3_CUSTOM_DOMAIN=
